{
  "name": "dashboard-magui",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "check-i18n": "node scripts/check-i18n.mjs",
    "build": "pnpm check-i18n && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:db": "node scripts/db-audit.mjs",
    "lint:secrets": "secretlint \"**/*\"",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate": "plop",
    "typecheck": "tsc --noEmit",
    "db:audit": "node scripts/db-audit.mjs",
    "analyze": "ANALYZE=true pnpm build",
    "audit": "unlighthouse --site http://localhost:3000",
    "clean": "node -e \"['.next', 'node_modules', 'pnpm-lock.yaml'].forEach(p => require('fs').rmSync(p, { recursive: true, force: true }))\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/localizations": "^4.5.1",
    "@clerk/nextjs": "^7.2.1",
    "@clerk/ui": "^1.6.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@next/third-parties": "^16.2.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@uploadthing/react": "^7.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "js-cookie": "^3.0.5",
    "next": "16.1.7",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-country-flag": "^3.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "resend": "^6.12.2",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.15",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "get-port-please": "^3.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "plop": "^4.0.5",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "secretlint": "^11.4.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "unlighthouse": "^0.17.7",
    "vitest": "^4.1.2",
    "vitest-canvas-mock": "^1.1.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
