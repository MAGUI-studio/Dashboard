// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// Enum para as fases do seu Protocolo de Execução
enum ProjectStatus {
  STRATEGY // Estratégia
  ARCHITECTURE // Arquitetura
  DESIGN // Design
  ENGINEERING // Engenharia
  QA // Qualidade
  LAUNCHED // Finalizado/Lançado
}

enum ProjectCategory {
  WEB_APP
  MOBILE_APP
  BRANDING
  LANDING_PAGE
  SALES_PAGE
  INSTITUTIONAL_SITE
  E_COMMERCE
  UI_UX_DESIGN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Enum para tipos de arquivos no UploadThing
enum AssetType {
  CONTRACT
  DESIGN_SYSTEM
  IMAGE
  DOCUMENT
  SOURCE_CODE
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique // Link direto com o Auth do Clerk
  email     String    @unique
  name      String?
  role      String    @default("CLIENT") // ADMIN ou CLIENT
  
  // Informações adicionais para Autoridade Digital
  companyName String?
  phone       String?
  position    String?
  avatarUrl   String?
  taxId       String?

  projects  Project[] // Um cliente pode ter vários projetos
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(STRATEGY)
  progress    Int           @default(0) // 0 a 100
  budget      String?       // Para controle interno do Admin
  
  // Datas e Prazos
  startDate   DateTime      @default(now())
  deadline    DateTime?

  // Ativos e Links Rápidos
  liveUrl       String?
  repositoryUrl String?
  category      ProjectCategory @default(WEB_APP)
  priority      Priority        @default(MEDIUM)

  // Relacionamentos
  clientId String
  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  updates Update[] // A Timeline do projeto
  assets  Asset[] // Arquivos do UploadThing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Update {
  id          String  @id @default(cuid())
  title       String // Ex: "Design da Home Finalizado"
  description String? @db.Text
  isMilestone Boolean @default(false) // Se marcar como true, pode ter um destaque visual na UI
  imageUrl    String? // Screenshot ou imagem do progresso
  timezone    String  @default("UTC") // Fuso horário do momento do registro

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Asset {
  id   String    @id @default(cuid())
  name String // Nome visível do arquivo
  url  String // URL vinda do UploadThing
  key  String // Key do UploadThing para deleção futura
  type AssetType @default(DOCUMENT)
  order Int       @default(0) // Ordem de exibição
  timezone String  @default("UTC") // Fuso horário do upload

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
