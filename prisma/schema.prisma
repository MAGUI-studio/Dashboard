generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
  CLIENT
}

enum ProjectMemberRole {
  OWNER
  COLLABORATOR
}

enum ProjectStatus {
  STRATEGY
  ARCHITECTURE
  DESIGN
  ENGINEERING
  QA
  LAUNCHED
}

enum ProjectCategory {
  WEB_APP
  MOBILE_APP
  BRANDING
  LANDING_PAGE
  SALES_PAGE
  INSTITUTIONAL_SITE
  E_COMMERCE
  UI_UX_DESIGN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetType {
  CONTRACT
  DESIGN_SYSTEM
  IMAGE
  DOCUMENT
  SOURCE_CODE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionStatus {
  PENDING
  COMPLETED
}

enum ActionTargetRole {
  ADMIN
  CLIENT
}

enum AssetOrigin {
  ADMIN
  CLIENT
}

enum AssetVisibility {
  INTERNAL
  CLIENT
}

enum LeadStatus {
  GARIMPAGEM
  CONTATO_REALIZADO
  NEGOCIACAO
  CONVERTIDO
  DESCARTADO
}

enum LeadSource {
  REFERRAL
  ORGANIC
  INSTAGRAM
  LINKEDIN
  WEBSITE
  OUTBOUND
  EVENT
  OTHER
}

enum LeadActivityType {
  NOTE_CREATED
  STATUS_CHANGED
  SOURCE_UPDATED
  CONTACT_UPDATED
  WHATSAPP_LINK_OPENED
  LEAD_EDITED
  CONVERTED_TO_PROJECT
  REMINDER_SET
}

enum NotificationType {
  UPDATE_PENDING_APPROVAL
  UPDATE_PUBLISHED
  UPDATE_APPROVED
  UPDATE_REJECTED
  BRIEFING_SUBMITTED
  ASSET_UPLOADED
  PROJECT_STATUS_CHANGED
  LEAD_ASSIGNED
  OPERATIONAL_REMINDER
}

enum ScheduledReminderType {
  LEAD_STALLED
  APPROVAL_PENDING
  PROJECT_SILENT
  ACTION_ITEM_OVERDUE
}

enum ScheduledReminderStatus {
  PENDING
  SENT
  RESOLVED
  DISMISSED
}

enum AuditActorType {
  SYSTEM
  USER
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  role          UserRole       @default(CLIENT)

  companyName   String?
  phone         String?
  position      String?
  avatarUrl     String?
  taxId         String?

  projects      Project[]
  projectMemberships ProjectMember[]
  ownedLeads    Lead[]         @relation("LeadOwner")
  leadNotes     LeadNote[]     @relation("LeadNoteAuthor")
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  scheduledReminders ScheduledReminder[]

  comments      UpdateComment[]
  approvalEvents ApprovalEvent[]
  leadActivities LeadActivity[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Lead {
  id            String      @id @default(cuid())
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  instagram     String?
  status        LeadStatus  @default(GARIMPAGEM)
  source        LeadSource  @default(OTHER)
  notes         String?     @db.Text
  value         String?
  lastContactAt DateTime?
  nextActionAt  DateTime?

  assignedToId  String?
  assignedTo    User?       @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpNotes LeadNote[]
  activities    LeadActivity[]

  convertedProjectId String?
  convertedAt        DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([nextActionAt])
}

model LeadNote {
  id         String   @id @default(cuid())
  content    String   @db.Text

  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation("LeadNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([leadId])
  @@index([authorId])
  @@index([createdAt])
}

model LeadActivity {
  id         String           @id @default(cuid())
  type       LeadActivityType
  title      String
  content    String?          @db.Text
  metadata   Json?            @default("{}")

  leadId     String
  lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt  DateTime         @default(now())

  @@index([leadId])
  @@index([authorId])
  @@index([createdAt])
}

model MessageTemplate {
  id         String   @id @default(cuid())
  scope      String   @default("LEAD") // LEAD, PROJECT
  name       String
  content    String   @db.Text
  
  createdById String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SavedView {
  id          String   @id @default(cuid())
  userId      String
  module      String   // CRM, PROJECTS
  name        String
  filtersJson Json
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, module])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?         @db.Text
  status        ProjectStatus   @default(STRATEGY)
  category      ProjectCategory @default(WEB_APP)
  priority      Priority        @default(MEDIUM)
  progress      Int             @default(0)
  budget        String?
  
  briefing      Json?           @default("{}")
  briefingNotes BriefingEntry[]

  startDate     DateTime        @default(now())
  deadline      DateTime?
  liveUrl       String?
  repositoryUrl String?

  clientId      String
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members       ProjectMember[]
  
  updates       Update[]
  assets        Asset[]
  actionItems   ActionItem[]
  versions      Version[]
  notifications Notification[]
  auditLogs     AuditLog[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([updatedAt])
}

model BriefingEntry {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdById String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

model ProjectMember {
  id        String            @id @default(cuid())
  role      ProjectMemberRole @default(COLLABORATOR)

  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Update {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  isMilestone    Boolean        @default(false)
  imageUrl       String?
  timezone       String         @default("UTC")
  
  requiresApproval Boolean      @default(false)
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  feedback         String?      @db.Text

  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments    UpdateAttachment[]
  comments       UpdateComment[]
  approvalEvents ApprovalEvent[]

  createdAt      DateTime       @default(now())

  @@index([projectId])
  @@index([approvalStatus])
  @@index([createdAt])
}

model UpdateAttachment {
  id         String    @id @default(cuid())
  name       String
  url        String
  key        String
  customId   String?
  type       AssetType @default(DOCUMENT)
  mimeType   String?
  size       Int?

  updateId   String
  update     Update    @relation(fields: [updateId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@index([updateId])
  @@index([createdAt])
}

model UpdateComment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  
  updateId   String
  update     Update   @relation(fields: [updateId], references: [id], onDelete: Cascade)
  
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  attachments UpdateCommentAttachment[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updateId])
  @@index([authorId])
}

model UpdateCommentAttachment {
  id       String    @id @default(cuid())
  name     String
  url      String
  key      String
  customId String?
  type     AssetType @default(DOCUMENT)
  mimeType String?
  size     Int?

  commentId String
  comment   UpdateComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([createdAt])
}

model ApprovalEvent {
  id         String         @id @default(cuid())
  decision   ApprovalStatus
  comment    String?        @db.Text
  
  updateId   String
  update     Update         @relation(fields: [updateId], references: [id], onDelete: Cascade)
  
  actorId    String?
  actor      User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  
  createdAt  DateTime       @default(now())

  @@index([updateId])
  @@index([actorId])
}

model ActionItem {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      ActionStatus @default(PENDING)
  dueDate     DateTime?
  targetRole  ActionTargetRole @default(ADMIN)

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([targetRole])
}

model Asset {
  id          String          @id @default(cuid())
  name        String
  url         String
  key         String
  type        AssetType       @default(DOCUMENT)
  order       Int             @default(0)
  timezone    String          @default("UTC")
  
  origin      AssetOrigin     @default(ADMIN)
  visibility  AssetVisibility @default(CLIENT)

  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([projectId])
  @@index([order])
  @@index([visibility])
}

model Version {
  id          String   @id @default(cuid())
  name        String
  deployUrl   String?
  description String?  @db.Text
  
  scorePerformance Int?
  scoreAccessibility Int?
  scoreBestPractices Int?
  scoreSEO Int?

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  ctaPath   String?
  metadata  Json?
  readAt    DateTime?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@index([projectId])
}

model ScheduledReminder {
  id              String                  @id @default(cuid())
  type            ScheduledReminderType
  status          ScheduledReminderStatus @default(PENDING)
  entityType      String
  entityId        String
  title           String
  message         String                  @db.Text
  ctaPath         String?
  scheduledFor    DateTime
  sentAt          DateTime?
  resolvedAt      DateTime?
  metadata        Json?

  recipientUserId String
  recipientUser   User                    @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([recipientUserId, status])
  @@index([type, status])
  @@index([scheduledFor])
  @@index([entityType, entityId])
  @@unique([recipientUserId, type, entityId])
}

model AuditLog {
  id        String         @id @default(cuid())
  action    String
  entityType String
  entityId  String
  summary   String
  metadata  Json?
  actorType AuditActorType @default(SYSTEM)

  actorId   String?
  actor     User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())

  @@index([projectId])
  @@index([actorId])
  @@index([createdAt])
  @@index([entityType, entityId])
}
