generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum UserRole {
  ADMIN
  MEMBER
  CLIENT
}

enum ProjectMemberRole {
  OWNER
  COLLABORATOR
}

enum ProjectStatus {
  STRATEGY
  ARCHITECTURE
  DESIGN
  ENGINEERING
  QA
  LAUNCHED
}

enum ProjectCategory {
  WEB_APP
  MOBILE_APP
  BRANDING
  LANDING_PAGE
  SALES_PAGE
  INSTITUTIONAL_SITE
  E_COMMERCE
  UI_UX_DESIGN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetType {
  CONTRACT
  DESIGN_SYSTEM
  IMAGE
  DOCUMENT
  SOURCE_CODE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionStatus {
  PENDING
  COMPLETED
}

enum ActionTargetRole {
  ADMIN
  CLIENT
}

enum AssetOrigin {
  ADMIN
  CLIENT
}

enum AssetVisibility {
  INTERNAL
  CLIENT
}

enum LeadStatus {
  GARIMPAGEM
  CONTATO_REALIZADO
  NEGOCIACAO
  CONVERTIDO
  DESCARTADO
}

enum LeadSource {
  REFERRAL
  ORGANIC
  INSTAGRAM
  LINKEDIN
  WEBSITE
  OUTBOUND
  EVENT
  OTHER
}

enum LeadActivityType {
  NOTE_CREATED
  STATUS_CHANGED
  SOURCE_UPDATED
  CONTACT_UPDATED
  WHATSAPP_LINK_OPENED
  LEAD_EDITED
  CONVERTED_TO_PROJECT
  REMINDER_SET
}

enum NotificationType {
  UPDATE_PENDING_APPROVAL
  UPDATE_PUBLISHED
  UPDATE_APPROVED
  UPDATE_REJECTED
  BRIEFING_SUBMITTED
  ASSET_UPLOADED
  PROJECT_STATUS_CHANGED
  LEAD_ASSIGNED
  OPERATIONAL_REMINDER
}

enum ScheduledReminderType {
  LEAD_STALLED
  APPROVAL_PENDING
  PROJECT_SILENT
  ACTION_ITEM_OVERDUE
}

enum ScheduledReminderStatus {
  PENDING
  SENT
  RESOLVED
  DISMISSED
}

enum AuditActorType {
  SYSTEM
  USER
}

model DashboardMetricSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  
  // Projects
  activeProjects     Int
  completedProjects  Int
  pendingApprovals   Int
  
  // CRM
  totalLeads         Int
  convertedLeads     Int
  negotiationValue   Float
  
  // Performance
  avgApprovalHours   Float
  
  createdAt DateTime @default(now())

  @@index([date])
}

model SearchDocument {
  id          String   @id @default(cuid())
  entityType  String   // User, Project, Lead, Asset, Update
  entityId    String
  projectId   String?
  
  title       String
  subtitle    String?
  body        String?  @db.Text
  
  metadata    Json?
  
  updatedAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([projectId])
}

model EventOutbox {
  id          String   @id @default(cuid())
  type        String   // NOTIFICATION, AUDIT, SEARCH_SYNC
  payload     Json
  status      String   @default("PENDING") // PENDING, PROCESSED, FAILED
  error       String?  @db.Text
  attempts    Int      @default(0)
  
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  role          UserRole       @default(CLIENT)

  companyName   String?
  phone         String?
  position      String?
  avatarUrl     String?
  taxId         String?

  projects      Project[]
  projectMemberships ProjectMember[]
  ownedLeads    Lead[]         @relation("LeadOwner")
  leadNotes     LeadNote[]     @relation("LeadNoteAuthor")
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  scheduledReminders ScheduledReminder[]

  approvalEvents ApprovalEvent[]
  leadActivities LeadActivity[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Lead {
  id            String      @id @default(cuid())
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  instagram     String?
  status        LeadStatus  @default(GARIMPAGEM)
  source        LeadSource  @default(OTHER)
  notes         String?     @db.Text
  value         String?
  lastContactAt DateTime?
  nextActionAt  DateTime?

  assignedToId  String?
  assignedTo    User?       @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpNotes LeadNote[]
  activities    LeadActivity[]
  proposals     Proposal[]

  convertedProjectId String?
  convertedAt        DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status, updatedAt])
  @@index([status, nextActionAt])
  @@index([assignedToId, status, updatedAt])
  @@index([convertedProjectId])
}

model LeadNote {
  id         String   @id @default(cuid())
  content    String   @db.Text

  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation("LeadNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([leadId])
  @@index([authorId])
  @@index([createdAt])
}

model LeadActivity {
  id         String           @id @default(cuid())
  type       LeadActivityType
  title      String
  content    String?          @db.Text
  metadata   Json?            @default("{}")

  leadId     String
  lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt  DateTime         @default(now())

  @@index([leadId])
  @@index([authorId])
  @@index([createdAt])
}

model MessageTemplate {
  id         String   @id @default(cuid())
  scope      String   @default("LEAD") // LEAD, PROJECT
  name       String
  content    String   @db.Text
  
  createdById String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([scope, createdAt])
}

model SavedView {
  id          String   @id @default(cuid())
  userId      String
  module      String   // CRM, PROJECTS
  name        String
  filtersJson Json
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, module, name])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?         @db.Text
  status        ProjectStatus   @default(STRATEGY)
  category      ProjectCategory @default(WEB_APP)
  priority      Priority        @default(MEDIUM)
  progress      Int             @default(0)
  budget        String?
  
  briefing      Json?           @default("{}")
  briefingNotes BriefingEntry[]

  startDate     DateTime        @default(now())
  deadline      DateTime?
  liveUrl       String?
  repositoryUrl String?

  clientId      String
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members       ProjectMember[]
  
  updates       Update[]
  assets        Asset[]
  actionItems   ActionItem[]
  versions      Version[]
  notifications Notification[]
  auditLogs     AuditLog[]
  proposals     Proposal[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, updatedAt])
  @@index([clientId, updatedAt])
}

model BriefingEntry {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdById String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

model ProjectMember {
  id        String            @id @default(cuid())
  role      ProjectMemberRole @default(COLLABORATOR)

  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Update {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  isMilestone    Boolean        @default(false)
  imageUrl       String?
  timezone       String         @default("UTC")
  
  requiresApproval Boolean      @default(false)
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  feedback         String?      @db.Text

  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments    UpdateAttachment[]
  approvalEvents ApprovalEvent[]

  createdAt      DateTime       @default(now())

  @@index([projectId, createdAt])
  @@index([requiresApproval, approvalStatus, createdAt])
}

model UpdateAttachment {
  id         String    @id @default(cuid())
  name       String
  url        String
  key        String
  customId   String?
  type       AssetType @default(DOCUMENT)
  mimeType   String?
  size       Int?

  updateId   String
  update     Update    @relation(fields: [updateId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@index([updateId, createdAt])
}

model ApprovalEvent {
  id         String         @id @default(cuid())
  decision   ApprovalStatus
  comment    String?        @db.Text
  
  updateId   String
  update     Update         @relation(fields: [updateId], references: [id], onDelete: Cascade)
  
  actorId    String?
  actor      User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  
  createdAt  DateTime       @default(now())

  @@index([updateId])
  @@index([actorId])
}

model ActionItem {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      ActionStatus @default(PENDING)
  dueDate     DateTime?
  targetRole  ActionTargetRole @default(ADMIN)

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, dueDate])
  @@index([projectId, status, dueDate])
  @@index([targetRole])
}

model Asset {
  id          String          @id @default(cuid())
  name        String
  url         String
  key         String
  type        AssetType       @default(DOCUMENT)
  order       Int             @default(0)
  timezone    String          @default("UTC")
  
  origin      AssetOrigin     @default(ADMIN)
  visibility  AssetVisibility @default(CLIENT)

  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([projectId, visibility, order])
  @@index([projectId, createdAt])
}

model Version {
  id          String   @id @default(cuid())
  name        String
  deployUrl   String?
  description String?  @db.Text
  
  scorePerformance Int?
  scoreAccessibility Int?
  scoreBestPractices Int?
  scoreSEO Int?

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  ctaPath   String?
  metadata  Json?
  readAt    DateTime?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([projectId])
}

model ScheduledReminder {
  id              String                  @id @default(cuid())
  type            ScheduledReminderType
  status          ScheduledReminderStatus @default(PENDING)
  entityType      String
  entityId        String
  title           String
  message         String                  @db.Text
  ctaPath         String?
  scheduledFor    DateTime
  sentAt          DateTime?
  resolvedAt      DateTime?
  metadata        Json?

  recipientUserId String
  recipientUser   User                    @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([recipientUserId, status, scheduledFor])
  @@index([type, status])
  @@index([entityType, entityId])
  @@unique([recipientUserId, type, entityId])
}

model AuditLog {
  id        String         @id @default(cuid())
  action    String
  entityType String
  entityId  String
  summary   String
  metadata  Json?
  actorType AuditActorType @default(SYSTEM)

  actorId   String?
  actor     User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())

  @@index([projectId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}

model Proposal {
  id          String         @id @default(cuid())
  number      Int            @default(autoincrement())
  title       String
  status      ProposalStatus @default(DRAFT)
  validUntil  DateTime?
  totalValue  Float          @default(0)
  currency    String         @default("BRL")
  notes       String?        @db.Text
  
  acceptedAt  DateTime?
  acceptedIp  String?
  
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  items       ProposalItem[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leadId])
  @@index([status])
}

model ProposalItem {
  id              String   @id @default(cuid())
  description     String
  longDescription String?  @db.Text
  unitValue       Float    @default(0)
  quantity        Int      @default(1)
  order           Int      @default(0)
  
  proposalId      String
  proposal        Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([proposalId, order])
}

model ProposalBlock {
  id        String   @id @default(cuid())
  category  String   // EXECUTIVE_SUMMARY, OBJECTIVES, etc.
  title     String
  content   String   @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
