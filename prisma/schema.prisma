// -----------------------------------------------------------------------------
// CONFIGURAÇÃO BASE
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS (OS PILARES DO PROTOCOLO)
// -----------------------------------------------------------------------------

enum ProjectStatus {
  STRATEGY
  ARCHITECTURE
  DESIGN
  ENGINEERING
  QA
  LAUNCHED
}

enum ProjectCategory {
  WEB_APP
  MOBILE_APP
  BRANDING
  LANDING_PAGE
  SALES_PAGE
  INSTITUTIONAL_SITE
  E_COMMERCE
  UI_UX_DESIGN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetType {
  CONTRACT
  DESIGN_SYSTEM
  IMAGE
  DOCUMENT
  SOURCE_CODE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionStatus {
  PENDING
  COMPLETED
}

enum LeadStatus {
  GARIMPAGEM
  CONTATO_REALIZADO
  NEGOCIACAO
  CONVERTIDO
  DESCARTADO
}

// -----------------------------------------------------------------------------
// MODELOS DE USUÁRIO E CRM (FUNIL DE VENDAS)
// -----------------------------------------------------------------------------

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  name        String?
  role        String   @default("CLIENT") // ADMIN | CLIENT
  
  companyName String?
  phone       String?
  position    String?
  avatarUrl   String?
  taxId       String?

  projects    Project[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          String     @id @default(cuid())
  companyName String
  contactName String?
  email       String?
  phone       String?
  website     String?    // Site atual (ruim) do prospect
  instagram   String?
  status      LeadStatus @default(GARIMPAGEM)
  notes       String?    @db.Text // Observações estratégicas
  value       String?    // Estimativa de ticket
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// -----------------------------------------------------------------------------
// NÚCLEO DO PROJETO
// -----------------------------------------------------------------------------

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?         @db.Text
  status        ProjectStatus   @default(STRATEGY)
  category      ProjectCategory @default(WEB_APP)
  priority      Priority        @default(MEDIUM)
  progress      Int             @default(0)
  budget        String?
  
  // Briefing Dinâmico (Armazenado como JSON para flexibilidade total)
  briefing      Json?           @default("{}")

  // Datas e Links
  startDate     DateTime        @default(now())
  deadline      DateTime?
  liveUrl       String?
  repositoryUrl String?

  // Relacionamentos
  clientId      String
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  updates       Update[]
  assets        Asset[]
  actionItems   ActionItem[]    // Pendências do cliente
  versions      Version[]       // Logs de Preview e Performance

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// -----------------------------------------------------------------------------
// TIMELINE E APROVAÇÕES (ESCUDO JURÍDICO)
// -----------------------------------------------------------------------------

model Update {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  isMilestone    Boolean        @default(false)
  imageUrl       String?
  timezone       String         @default("UTC")
  
  // Lógica de Aprovação
  requiresApproval Boolean      @default(false)
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  feedback         String?      @db.Text // Caso o cliente rejeite

  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime       @default(now())
}

// -----------------------------------------------------------------------------
// PENDÊNCIAS, ASSETS E VERSÕES (RIGOR TÉCNICO)
// -----------------------------------------------------------------------------

model ActionItem {
  id          String       @id @default(cuid())
  title       String       // Ex: "Enviar Logotipo em Vetor"
  description String?      @db.Text
  status      ActionStatus @default(PENDING)
  dueDate     DateTime?

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Asset {
  id          String    @id @default(cuid())
  name        String
  url         String
  key         String    // Para deleção no UploadThing
  type        AssetType @default(DOCUMENT)
  order       Int       @default(0)
  timezone    String    @default("UTC")

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
}

model Version {
  id          String   @id @default(cuid())
  name        String   // Ex: "v1.0.4 - Alpha"
  deployUrl   String?
  description String?  @db.Text
  
  // Relatório de Performance (Lighthouse)
  scorePerformance Int?
  scoreAccessibility Int?
  scoreBestPractices Int?
  scoreSEO Int?

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}
