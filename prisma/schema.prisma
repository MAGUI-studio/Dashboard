generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
  CLIENT
}

enum ProjectStatus {
  STRATEGY
  ARCHITECTURE
  DESIGN
  ENGINEERING
  QA
  LAUNCHED
}

enum ProjectCategory {
  WEB_APP
  MOBILE_APP
  BRANDING
  LANDING_PAGE
  SALES_PAGE
  INSTITUTIONAL_SITE
  E_COMMERCE
  UI_UX_DESIGN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetType {
  CONTRACT
  DESIGN_SYSTEM
  IMAGE
  DOCUMENT
  SOURCE_CODE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionStatus {
  PENDING
  COMPLETED
}

enum LeadStatus {
  GARIMPAGEM
  CONTATO_REALIZADO
  NEGOCIACAO
  CONVERTIDO
  DESCARTADO
}

enum LeadSource {
  REFERRAL
  ORGANIC
  INSTAGRAM
  LINKEDIN
  WEBSITE
  OUTBOUND
  EVENT
  OTHER
}

enum NotificationType {
  UPDATE_PENDING_APPROVAL
  UPDATE_APPROVED
  UPDATE_REJECTED
  BRIEFING_SUBMITTED
  ASSET_UPLOADED
  PROJECT_STATUS_CHANGED
  LEAD_ASSIGNED
}

enum AuditActorType {
  SYSTEM
  USER
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  role          UserRole       @default(CLIENT)

  companyName   String?
  phone         String?
  position      String?
  avatarUrl     String?
  taxId         String?

  projects      Project[]
  ownedLeads    Lead[]         @relation("LeadOwner")
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Lead {
  id            String      @id @default(cuid())
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  instagram     String?
  status        LeadStatus  @default(GARIMPAGEM)
  source        LeadSource  @default(OTHER)
  notes         String?     @db.Text
  value         String?
  lastContactAt DateTime?
  nextActionAt  DateTime?

  assignedToId  String?
  assignedTo    User?       @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([nextActionAt])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?         @db.Text
  status        ProjectStatus   @default(STRATEGY)
  category      ProjectCategory @default(WEB_APP)
  priority      Priority        @default(MEDIUM)
  progress      Int             @default(0)
  budget        String?
  
  briefing      Json?           @default("{}")

  startDate     DateTime        @default(now())
  deadline      DateTime?
  liveUrl       String?
  repositoryUrl String?

  clientId      String
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  updates       Update[]
  assets        Asset[]
  actionItems   ActionItem[]
  versions      Version[]
  notifications Notification[]
  auditLogs     AuditLog[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([updatedAt])
}

model Update {
  id             String         @id @default(cuid())
  title          String
  description    String?        @db.Text
  isMilestone    Boolean        @default(false)
  imageUrl       String?
  timezone       String         @default("UTC")
  
  requiresApproval Boolean      @default(false)
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  feedback         String?      @db.Text

  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt      DateTime       @default(now())

  @@index([projectId])
  @@index([approvalStatus])
  @@index([createdAt])
}

model ActionItem {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      ActionStatus @default(PENDING)
  dueDate     DateTime?

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model Asset {
  id          String    @id @default(cuid())
  name        String
  url         String
  key         String
  type        AssetType @default(DOCUMENT)
  order       Int       @default(0)
  timezone    String    @default("UTC")

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@index([projectId])
  @@index([order])
}

model Version {
  id          String   @id @default(cuid())
  name        String
  deployUrl   String?
  description String?  @db.Text
  
  scorePerformance Int?
  scoreAccessibility Int?
  scoreBestPractices Int?
  scoreSEO Int?

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  ctaPath   String?
  metadata  Json?
  readAt    DateTime?

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@index([projectId])
}

model AuditLog {
  id        String         @id @default(cuid())
  action    String
  entityType String
  entityId  String
  summary   String
  metadata  Json?
  actorType AuditActorType @default(SYSTEM)

  actorId   String?
  actor     User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())

  @@index([projectId])
  @@index([actorId])
  @@index([createdAt])
  @@index([entityType, entityId])
}
